# ─────────────────────────────────────────────────────────────────────────────
# Grabbite — environment configuration template (MED-14)
# ─────────────────────────────────────────────────────────────────────────────
# Copy to `.env` for local development, or pass via:
#   docker run --env-file .env grabbite:latest
#   gunicorn --env-file .env app:app
# NEVER commit the real `.env` to source control.
#
# Sections:
#   1. Flask core           — secret key, debug, host/port
#   2. Database              — DATABASE_URL
#   3. Mail (SMTP)           — outbound transactional mail
#   4. Payment gateway       — Razorpay keys + webhook secret
#   5. Production admin      — bootstrap admin credentials (prod only)
#   6. Session / tokens      — itsdangerous salting
#   7. Realtime              — SocketIO allowed origins
#   8. Rate limiting         — Redis backend for Flask-Limiter
#   9. Server (gunicorn)     — runtime tuning, also in gunicorn.conf.py
# ─────────────────────────────────────────────────────────────────────────────


# ─── 1. Flask core ──────────────────────────────────────────────────────────
# REQUIRED in production. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=replace-me-with-a-64-byte-url-safe-random-string

# 'development' | 'production' — controls debug mode, dev admin seeding, etc.
FLASK_ENV=development

# Off in prod (boots the Werkzeug debugger if True).
# In dev, set to '1' for autoreload + tracebacks. Default is off everywhere.
FLASK_DEBUG=1

# Bind address for the dev server. Loopback by default — change to 0.0.0.0
# only in trusted networks (gunicorn handles production binding).
HOST=127.0.0.1
PORT=5000


# ─── 2. Database ────────────────────────────────────────────────────────────
# SQLite default (no setup needed):
#   DATABASE_URL=sqlite:///grabbite.db
# PostgreSQL (recommended for production):
#   DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/grabbite
# MySQL:
#   DATABASE_URL=mysql+pymysql://USER:PASSWORD@HOST:3306/grabbite
DATABASE_URL=sqlite:///grabbite.db


# ─── 3. Mail (SMTP) ─────────────────────────────────────────────────────────
# Used for order confirmations, password resets, welcome emails.
# Leave MAIL_SERVER blank to silently disable email (safe for dev).

# Gmail example:
#   MAIL_SERVER=smtp.gmail.com
#   MAIL_PORT=587
#   MAIL_USE_TLS=1
#   MAIL_USERNAME=your-gmail@gmail.com
#   MAIL_PASSWORD=your-app-password        # Use an App Password, not your account password
#   MAIL_DEFAULT_SENDER=GrabBite <your-gmail@gmail.com>
#
# SendGrid example:
#   MAIL_SERVER=smtp.sendgrid.net
#   MAIL_USERNAME=apikey
#   MAIL_PASSWORD=SG.xxxxx...
#
# AWS SES (SMTP) example:
#   MAIL_SERVER=email-smtp.us-east-1.amazonaws.com
#   MAIL_USERNAME=AKIAIOSFODNN7EXAMPLE
#   MAIL_PASSWORD=your-ses-smtp-password

MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_USE_SSL=0
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=GrabBite <noreply@grabbite.com>


# ─── 4. Payment gateway (Razorpay) ──────────────────────────────────────────
# Generate in the Razorpay dashboard → Settings → API Keys.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Webhook signing secret — Razorpay dashboard → Webhooks → each webhook.
# CRITICAL: rotating this invalidates all in-flight retries; keep stable.
RAZORPAY_WEBHOOK_SECRET=


# ─── 5. Production admin (bootstrap) ────────────────────────────────────────
# Read ONLY in production AND ONLY when no admin user exists yet.
# After first successful login, change the password and rotate these out
# of the deployment environment. In dev a random password is generated
# and printed on startup — no env vars needed.
ADMIN_EMAIL=
ADMIN_PASSWORD=


# ─── 6. Session / token salts ───────────────────────────────────────────────
# Salt for itsdangerous password-reset tokens. Rotating invalidates all
# outstanding reset links. Keep stable across deploys.
RESET_TOKEN_SALT=grabbite-password-reset

# Optional dev-only secret seed for deterministic sessions. Leave unset.
# DEV_SECRET_SEED=


# ─── 7. Realtime (SocketIO) ─────────────────────────────────────────────────
# Comma-separated list of allowed origins for the WebSocket handshake.
# In prod set to the public HTTPS origin(s).
SOCKETIO_ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000


# ─── 8. Rate limiting (Flask-Limiter) ───────────────────────────────────────
# In-memory by default (single-worker only). For prod, point at Redis.
#   REDIS_URL=redis://REDIS_PASSWORD@HOST:6379/0
# Leave at 'memory://' to use the default in-process backend.
REDIS_URL=memory://


# ─── 9. Server (gunicorn) ───────────────────────────────────────────────────
# All overrides for the production WSGI server. Also tunable via the
# command line; values here are picked up by gunicorn.conf.py.
GUNICORN_BIND=0.0.0.0:8000
GUNICORN_WORKERS=4
GUNICORN_THREADS=4
GUNICORN_WORKER_CLASS=gthread
GUNICORN_TIMEOUT=60
GUNICORN_LOG_LEVEL=info
GUNICORN_ACCESS_LOG=-
GUNICORN_ERROR_LOG=-
# GUNICORN_USER=grabbite
# GUNICORN_GROUP=grabbite
